{
  "manifest_version": 3,
  "name": "dkitle",
  "version": "1.0.0",
  "description": "Extract subtitles from video sites and send to dkitle desktop app",
  "browser_specific_settings": {
    "gecko": {
      "id": "dkitle@ywxt",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [],
  "host_permissions": ["http://127.0.0.1:9877/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["providers/intercept-base.js", "providers/youtube-intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["providers/provider-base.js", "providers/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["providers/intercept-base.js", "providers/bilibili-intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["providers/provider-base.js", "providers/bilibili.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "dkitle",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ws://127.0.0.1:9877 http://127.0.0.1:9877;"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
